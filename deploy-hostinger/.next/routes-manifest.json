{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/operacoes/[id]",
      "regex": "^/api/operacoes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/operacoes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/sinistros/[id]",
      "regex": "^/api/sinistros/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/sinistros/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/sinistros/[id]/anexos",
      "regex": "^/api/sinistros/([^/]+?)/anexos(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/sinistros/(?<nxtPid>[^/]+?)/anexos(?:/)?$"
    },
    {
      "page": "/api/sinistros/[id]/historico",
      "regex": "^/api/sinistros/([^/]+?)/historico(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/sinistros/(?<nxtPid>[^/]+?)/historico(?:/)?$"
    },
    {
      "page": "/api/sinistros/[id]/inconsistencias",
      "regex": "^/api/sinistros/([^/]+?)/inconsistencias(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/sinistros/(?<nxtPid>[^/]+?)/inconsistencias(?:/)?$"
    },
    {
      "page": "/api/sinistros/[id]/inconsistencias/[incId]",
      "regex": "^/api/sinistros/([^/]+?)/inconsistencias/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPincId": "nxtPincId"
      },
      "namedRegex": "^/api/sinistros/(?<nxtPid>[^/]+?)/inconsistencias/(?<nxtPincId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/usuarios/[id]",
      "regex": "^/api/usuarios/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/usuarios/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/sinistros/[id]",
      "regex": "^/sinistros/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/sinistros/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
